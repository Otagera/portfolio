---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-[#0a0a0a] text-gray-100 selection:bg-teal-500/30">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Othniel Agera - Backend Engineer Portfolio" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet">
	</head>
	<body class="font-mono leading-relaxed antialiased">
		<main class="mx-auto max-w-[80ch] px-6 py-24 min-h-screen">
			<slot />
		</main>
	</body>
</html>

<style is:global>
	:root {
		--accent: 20, 184, 166;
	}
	html {
		scroll-behavior: smooth;
	}
	body {
		background-size: 20px 20px;
		background-image: radial-gradient(circle, #1a1a1a 1px, transparent 1px);
	}
</style>
