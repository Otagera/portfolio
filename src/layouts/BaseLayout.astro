---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-[#0a0a0a] text-gray-100 selection:bg-teal-500/30">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		
		<title>{title}</title>
		<meta name="description" content="Backend Engineer specializing in distributed systems, performance optimization, and scalable architectures. Currently at Flutterwave." />
		<link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content="Backend Engineer specializing in distributed systems and performance optimization." />
		<meta property="og:image" content={new URL('/favicon.png', Astro.site)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content="Backend Engineer specializing in distributed systems and performance optimization." />
		<meta property="twitter:image" content={new URL('/favicon.png', Astro.site)} />

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet">
	</head>
	<body class="font-mono leading-relaxed antialiased">
		<main class="mx-auto max-w-[80ch] px-6 py-24 min-h-screen">
			<slot />
		</main>
	</body>
</html>

<style is:global>
	:root {
		--accent: 20, 184, 166;
	}
	html {
		scroll-behavior: smooth;
	}
	body {
		background-size: 20px 20px;
		background-image: radial-gradient(circle, #1a1a1a 1px, transparent 1px);
	}
</style>
