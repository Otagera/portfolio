---
import { getCollection } from 'astro:content';
import projects from '../data/projects.json';
import { getAllViews } from '../lib/db';

interface Props {
	writingLimit?: number;
}

const { writingLimit } = Astro.props;

const allWriting = (await getCollection('writing', ({ data }) => {
	return import.meta.env.PROD ? data.draft !== true : true;
})).sort((a, b) => {
	const dateDiff = b.data.date.getTime() - a.data.date.getTime();
	if (dateDiff !== 0) return dateDiff;
	return a.data.title.localeCompare(b.data.title);
});

const writing = writingLimit ? allWriting.slice(0, writingLimit) : allWriting;
const hasMoreWriting = writingLimit ? allWriting.length > writingLimit : false;

const views = getAllViews();

const formatDate = (date: Date) => {
	return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
};
---

<div class="space-y-24">
  <!-- Projects Section -->
  <section id="projects" class="space-y-8">
    <div class="text-teal-600 dark:text-teal-400 font-bold transition-colors">$ ls -la projects/</div>
    <div class="space-y-12">
      {projects.map((project) => (
        <div class="group border-l-2 border-gray-200 dark:border-gray-800 pl-6 py-2 hover:border-teal-600 dark:hover:border-teal-400 transition-all duration-200">
          <div class="flex justify-between items-baseline mb-2">
            <a href={project.link} target="_blank" class="text-lg font-bold text-teal-700 dark:text-teal-300 hover:text-teal-600 dark:hover:text-teal-200 transition-all">
              {project.title}
            </a>
            <span class="text-xs text-gray-500 dark:text-gray-500 font-mono">{project.year}</span>
          </div>
          <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed mb-4 transition-colors">
            {project.desc}
          </p>
          <div class="flex flex-wrap gap-3">
            {project.tech.map((t) => (
              <span class="text-[10px] uppercase tracking-wider text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-900/50 px-2 py-1 rounded border border-gray-200 dark:border-gray-800 transition-colors">
                {t}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Writing Section -->
  <section id="writing" class="space-y-8">
    <div class="text-teal-600 dark:text-teal-400 font-bold transition-colors">$ cat writing/{writingLimit ? 'latest_logs.md' : 'all_logs.md'}</div>
    <div class="space-y-10">
      {writing.map((post) => (
        <a href={`/writing/${post.slug}`} class="block group">
          <article>
            <div class="flex justify-between items-baseline mb-1">
              <h3 class="text-lg font-bold text-gray-800 dark:text-gray-100 group-hover:text-teal-600 dark:group-hover:text-teal-300 transition-colors">
                {post.data.title}
              </h3>
              <div class="flex items-center space-x-2 text-xs font-mono text-gray-500 dark:text-gray-600 transition-colors">
                <time class="whitespace-nowrap">
                  {formatDate(post.data.date)}
                </time>
                {post.data.updatedDate && <span class="italic text-[10px] opacity-70">(Edited)</span>}
                <span class="text-gray-300 dark:text-gray-800 mx-1">•</span>
                <span class="text-[10px] whitespace-nowrap">
                  {views[post.slug] || 0} views
                </span>
              </div>
            </div>
            <p class="text-gray-600 dark:text-gray-400 text-sm mb-3 group-hover:text-gray-900 dark:group-hover:text-gray-200 transition-colors">
              {post.data.summary}
            </p>
            <div class="flex items-center justify-between">
              <div class="flex gap-3">
                {post.data.tags?.map(tag => (
                  <span 
                    onclick="arguments[0].preventDefault(); arguments[0].stopPropagation(); window.location.href='/writing/tag/' + this.textContent.trim().substring(1)"
                    class="text-[10px] text-gray-500 dark:text-gray-500 font-mono italic hover:text-teal-600 dark:hover:text-teal-400 cursor-pointer transition-colors"
                  >
                    #{tag}
                  </span>
                ))}
              </div>
              <div class="text-[10px] text-teal-700 dark:text-teal-400 font-bold uppercase tracking-widest transition-colors">
                {post.data.readTime} READ
              </div>
            </div>
          </article>
        </a>
      ))}
      
      {hasMoreWriting && (
        <div class="pt-4">
          <a href="/writing" class="text-sm text-teal-600 dark:text-teal-400 hover:text-teal-700 dark:hover:text-teal-300 transition-all font-mono">
            $ cd writing/ && ls -la
          </a>
        </div>
      )}
    </div>
  </section>
</div>