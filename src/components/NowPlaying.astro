---
import { getNowPlaying } from '../lib/lastfm';

const LASTFM_API_KEY = import.meta.env.LASTFM_API_KEY;
const LASTFM_USERNAME = import.meta.env.LASTFM_USERNAME;

const track = (LASTFM_API_KEY && LASTFM_USERNAME) 
  ? await getNowPlaying(LASTFM_USERNAME, LASTFM_API_KEY) 
  : null;

const isPlaying = track?.isPlaying;
---

{track && (
  <div class="flex flex-col space-y-4 pt-12">
    <div class="text-teal-600 dark:text-teal-400">$ cat signals/current_vibe.json</div>
    <div class="group relative flex items-center space-x-4 border-l-2 border-gray-100 dark:border-gray-800 pl-6 py-2 hover:border-teal-500 transition-all duration-300">
      {isPlaying && (
        <div class="absolute -left-[5px] top-1/2 -translate-y-1/2 w-2 h-2 bg-teal-500 rounded-full animate-ping"></div>
      )}
      
      <div class="flex-1 space-y-1">
        <div class="flex items-center justify-between">
          <span class="text-[10px] uppercase tracking-widest text-gray-400 dark:text-gray-500 font-bold">
            {track.type === 'podcast' ? (isPlaying ? "Currently Tuning In" : "Recent Podcast") : (isPlaying ? "Currently Listening" : "Recently Played")}
          </span>
          <a href={track.url} target="_blank" class="text-[10px] text-teal-600 dark:text-teal-400 hover:underline font-mono">
            last.fm &rarr;
          </a>
        </div>
        
        <div class="flex flex-col">
          <span class="text-lg font-bold text-gray-800 dark:text-gray-200 group-hover:text-teal-600 dark:group-hover:text-teal-300 transition-colors truncate">
            {track.name}
          </span>
          <span class="text-sm text-gray-500 dark:text-gray-400 font-mono">
            {track.artist} — {track.album}
          </span>
        </div>
      </div>
    </div>
  </div>
)}
