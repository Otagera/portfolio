---
import { getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getViews, incrementViews } from '../../lib/db';

const { slug } = Astro.params;
const entry = await getEntry('writing', slug);

if (!entry) {
	return Astro.redirect('/404');
}

// Backend logic: Increment views on the server
incrementViews(slug);
const viewCount = getViews(slug);

const { Content } = await entry.render();
---

<BaseLayout title={`${entry.data.title} | Othniel Agera`}>
  <Header />
  <article class="prose prose-invert prose-teal max-w-none pt-12">
    <div class="mb-12">
      <div class="text-teal-400 mb-4">$ cat writing/{slug}.md</div>
      <h1 class="text-4xl font-bold text-white mb-4">{entry.data.title}</h1>
      <div class="flex space-x-4 text-sm text-gray-500 font-mono">
        <span>{entry.data.date}</span>
        <span>•</span>
        <span>{entry.data.readTime} read</span>
        <span>•</span>
        <span class="text-teal-500">{viewCount} views</span>
      </div>
      {entry.data.tags && (
        <div class="flex gap-3 mt-4">
          {entry.data.tags.map(tag => (
            <a 
              href={`/writing/tag/${tag}`}
              class="text-xs text-teal-400/60 font-mono bg-teal-500/5 px-2 py-0.5 rounded border border-teal-500/10 hover:border-teal-500/30 hover:text-teal-400 transition-all"
            >
              #{tag}
            </a>
          ))}
        </div>
      )}
    </div>
    
    <div class="text-gray-300 leading-relaxed space-y-6">
      <Content />
    </div>

    <div class="mt-20 pt-10 border-t border-gray-800">
      <a href="/writing" class="text-teal-400 hover:text-teal-300 transition-colors">
        $ cd ..
      </a>
    </div>
  </article>
  <Footer />
</BaseLayout>