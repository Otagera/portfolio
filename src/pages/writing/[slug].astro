---
import { getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getViews, incrementViews } from '../../lib/db';

const { slug } = Astro.params;

if (!slug) {
	return Astro.redirect('/404');
}

const entry = await getEntry('writing', slug);

if (!entry || (import.meta.env.PROD && entry.data.draft)) {
	return Astro.redirect('/404');
}

// Backend logic: Increment views on the server
incrementViews(slug);
const viewCount = getViews(slug);

const { Content } = await entry.render();

const formatDate = (date: Date) => {
	return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
};
---

<BaseLayout title={`${entry.data.title} | Othniel Agera`}>
  <Header />
  <article class="prose dark:prose-invert prose-teal max-w-none pt-12 transition-colors">
    <div class="mb-12">
      <div class="text-teal-600 dark:text-teal-400 mb-4 transition-colors">$ cat writing/{slug}.md</div>
      <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-4 transition-colors">{entry.data.title}</h1>
      <div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-gray-500 dark:text-gray-500 font-mono transition-colors">
        <div class="flex items-center space-x-2">
          <span>{formatDate(entry.data.date)}</span>
          {entry.data.updatedDate && (
            <span class="italic text-xs opacity-70">
              (Edited {formatDate(entry.data.updatedDate)})
            </span>
          )}
        </div>
        <span class="text-gray-300 dark:text-gray-800">•</span>
        <span>{entry.data.readTime} read</span>
        <span class="text-gray-300 dark:text-gray-800">•</span>
        <span class="text-teal-600 dark:text-teal-500">{viewCount} views</span>
      </div>
      {entry.data.tags && (
        <div class="flex gap-3 mt-4">
          {entry.data.tags.map(tag => (
            <a 
              href={`/writing/tag/${tag}`}
              class="text-xs text-teal-600/60 dark:text-teal-400/60 font-mono bg-teal-600/5 dark:bg-teal-500/5 px-2 py-0.5 rounded border border-teal-600/10 dark:border-teal-500/10 hover:border-teal-600/30 dark:hover:border-teal-500/30 hover:text-teal-600 dark:hover:text-teal-400 transition-all"
            >
              #{tag}
            </a>
          ))}
        </div>
      )}
    </div>
    
    <div class="text-gray-700 dark:text-gray-300 leading-relaxed space-y-6 transition-colors">
      <Content />
    </div>

    <div class="mt-20 pt-10 border-t border-gray-200 dark:border-gray-800 transition-colors">
      <a href="/writing" class="text-teal-600 dark:text-teal-400 hover:opacity-80 transition-colors">
        $ cd ..
      </a>
    </div>
  </article>
  <Footer />
</BaseLayout>