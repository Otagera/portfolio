---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import projectsData from '../../data/projects.json';

interface Project {
	title: string;
	desc: string;
	task: string;
	tech: string[];
	link: string;
	year: string;
	featured?: boolean;
	writeup?: string;
	slug?: string;
}

const projects = projectsData as Project[];
---

<BaseLayout title="Projects | Othniel Agera">
  <Header />
  <section class="pt-12 space-y-12">
    <div class="space-y-4">
      <div class="text-teal-600 dark:text-teal-400 font-bold">$ ls -la projects/</div>
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white transition-colors">Projects</h1>
      <p class="text-gray-600 dark:text-gray-400 max-w-[60ch] transition-colors">
        Things I've designed and built, from database internals to AI photo
        tooling and the odd game. Each one is a deeper look at the what and the why.
      </p>
    </div>

    <div class="space-y-12 pt-8">
      {projects.map((project) => (
        <div class="group border-l-2 border-gray-200 dark:border-gray-800 pl-6 py-2 hover:border-teal-600 dark:hover:border-teal-400 transition-all duration-200">
          <div class="flex flex-col sm:flex-row sm:justify-between sm:items-baseline mb-2 gap-y-1 sm:gap-y-0">
            <a
              href={project.slug ? `/projects/${project.slug}` : project.link}
              target={project.slug ? undefined : '_blank'}
              class="text-xl font-bold text-teal-700 dark:text-teal-300 hover:text-teal-600 dark:hover:text-teal-200 transition-all"
            >
              {project.title}
            </a>
            <span class="text-xs text-gray-500 dark:text-gray-500 font-mono">{project.year}</span>
          </div>

          <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed mb-3 transition-colors">
            {project.desc}
          </p>

          <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mb-4 transition-colors">
            <span class="text-teal-700 dark:text-teal-400 font-bold">What I built:</span> {project.task}
          </p>

          <div class="flex flex-wrap gap-3 mb-4">
            {project.tech.map((t) => (
              <span class="text-[10px] uppercase tracking-wider text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-900/50 px-2 py-1 rounded border border-gray-200 dark:border-gray-800 transition-colors">
                {t}
              </span>
            ))}
          </div>

          <div class="flex flex-wrap gap-x-6 gap-y-2 text-[10px] font-bold uppercase tracking-widest">
            <a href={project.link} target="_blank" class="text-teal-700 dark:text-teal-400 hover:text-teal-600 dark:hover:text-teal-200 transition-colors">
              GitHub &rarr;
            </a>
            {project.writeup && (
              <a href={project.writeup} class="text-teal-700 dark:text-teal-400 hover:text-teal-600 dark:hover:text-teal-200 transition-colors">
                Read the writeup &rarr;
              </a>
            )}
          </div>
        </div>
      ))}
    </div>

    <div class="pt-20">
      <a href="/" class="text-teal-600 dark:text-teal-400 hover:opacity-80 transition-all font-mono">
        $ cd ..
      </a>
    </div>
  </section>
  <Footer />
</BaseLayout>
