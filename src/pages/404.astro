---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404: Command Not Found">
	<div class="space-y-8 py-12">
		<!-- System Diagnostic Header -->
		<div class="border border-red-500/30 bg-red-500/5 p-6 rounded-lg font-mono">
			<div class="flex items-center justify-between mb-4 border-b border-red-500/20 pb-2">
				<span class="text-red-500 font-bold">SYSTEM DIAGNOSTIC</span>
				<span class="text-red-600 dark:text-red-500">[STATUS: FAILED]</span>
			</div>
			
			<!-- Fake Boot Log -->
			<div class="text-[10px] md:text-xs text-gray-500 dark:text-gray-500 mb-4 space-y-1 opacity-80 transition-colors">
				<p>[ 0.000000] Initializing portfolio kernel...</p>
				<p>[ 0.124502] Loading modules: [typescript, astro, tailwind, strata-db]</p>
				<p>[ 0.458210] Memory: 640K (Actually much more, but let's be retro)</p>
				<p>[ 0.892114] Checking sector: {Astro.url.pathname} ...</p>
				<p class="text-red-600/80 dark:text-red-500/80">[ 1.024589] SECTOR_NOT_FOUND: Failed to map memory address to resource</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-2 text-sm">
				<div class="flex justify-between border-r border-gray-200 dark:border-red-500/10 pr-4 transition-colors">
					<span class="text-gray-500">MEMORY</span>
					<span class="text-teal-600 dark:text-teal-500">[OK]</span>
				</div>
				<div class="flex justify-between pl-4">
					<span class="text-gray-500">DISK</span>
					<span class="text-teal-600 dark:text-teal-500">[OK]</span>
				</div>
				<div class="flex justify-between border-r border-gray-200 dark:border-red-500/10 pr-4 transition-colors">
					<span class="text-gray-500">NETWORK</span>
					<span class="text-teal-600 dark:text-teal-500">[OK]</span>
				</div>
				<div class="flex justify-between pl-4">
					<span class="text-gray-500">PATH</span>
					<span class="text-red-600 dark:text-red-500">[ERROR_404]</span>
				</div>
			</div>
		</div>

		<!-- Command Not Found Section -->
		<div class="space-y-4 font-mono">
			<div class="flex items-center space-x-2">
				<span class="text-teal-600 dark:text-teal-500">➜</span>
				<span class="text-gray-500 dark:text-gray-400 transition-colors">~/guest</span>
				<span class="text-gray-900 dark:text-gray-100 italic transition-colors">cat {Astro.url.pathname}</span>
			</div>
			
			<div class="text-red-600 dark:text-red-400 overflow-hidden whitespace-nowrap border-r-2 border-red-600 dark:border-red-400 animate-[typewriter_2s_steps(40)_1s_forwards,blink_1s_infinite] w-0 transition-colors">
				404: Command Not Found. Resource missing in this sector.
			</div>
		</div>

		<!-- Navigation Suggestions -->
		<div class="space-y-6 pt-8">
			<h2 class="text-gray-500 dark:text-gray-400 text-sm uppercase tracking-widest border-b border-gray-200 dark:border-gray-800 pb-2 transition-colors">Available Commands</h2>
			<div class="grid gap-4">
				<a href="/" class="group flex items-center justify-between p-4 border border-gray-200 dark:border-gray-800 hover:border-teal-600 dark:hover:border-teal-500/50 hover:bg-teal-600/5 dark:hover:bg-teal-500/5 rounded transition-all">
					<div class="flex items-center space-x-3">
						<span class="text-teal-600 dark:text-teal-500 group-hover:translate-x-1 transition-transform">➜</span>
						<code class="text-gray-900 dark:text-gray-100 font-bold transition-colors">cd ~</code>
					</div>
					<span class="text-gray-500 text-sm italic group-hover:text-gray-700 dark:group-hover:text-gray-300 transition-colors">Return to root directory</span>
				</a>
				
				<a href="/writing" class="group flex items-center justify-between p-4 border border-gray-200 dark:border-gray-800 hover:border-teal-600 dark:hover:border-teal-500/50 hover:bg-teal-600/5 dark:hover:bg-teal-500/5 rounded transition-all">
					<div class="flex items-center space-x-3">
						<span class="text-teal-600 dark:text-teal-500 group-hover:translate-x-1 transition-transform">➜</span>
						<code class="text-gray-900 dark:text-gray-100 font-bold transition-colors">ls /writing</code>
					</div>
					<span class="text-gray-500 text-sm italic group-hover:text-gray-700 dark:group-hover:text-gray-300 transition-colors">Browse published logs</span>
				</a>

				<a href="/#projects" class="group flex items-center justify-between p-4 border border-gray-200 dark:border-gray-800 hover:border-teal-600 dark:hover:border-teal-500/50 hover:bg-teal-600/5 dark:hover:bg-teal-500/5 rounded transition-all">
					<div class="flex items-center space-x-3">
						<span class="text-teal-600 dark:text-teal-500 group-hover:translate-x-1 transition-transform">➜</span>
						<code class="text-gray-900 dark:text-gray-100 font-bold transition-colors">ls /#projects</code>
					</div>
					<span class="text-gray-500 text-sm italic group-hover:text-gray-700 dark:group-hover:text-gray-300 transition-colors">View engineering works</span>
				</a>

				<a href="/resume.pdf" target="_blank" class="group flex items-center justify-between p-4 border border-gray-200 dark:border-gray-800 hover:border-teal-600 dark:hover:border-teal-500/50 hover:bg-teal-600/5 dark:hover:bg-teal-500/5 rounded transition-all">
					<div class="flex items-center space-x-3">
						<span class="text-teal-600 dark:text-teal-500 group-hover:translate-x-1 transition-transform">➜</span>
						<code class="text-gray-900 dark:text-gray-100 font-bold transition-colors">cat resume.pdf</code>
					</div>
					<span class="text-gray-500 text-sm italic group-hover:text-gray-700 dark:group-hover:text-gray-300 transition-colors">Open personal manifest</span>
				</a>
			</div>
		</div>

		<div class="pt-12 text-center">
			<div class="inline-block w-3 h-6 bg-teal-600 dark:bg-teal-500 animate-[blink_1s_infinite]"></div>
		</div>
	</div>
</BaseLayout>

<style>
	@keyframes blink {
		0%, 100% { opacity: 1; }
		50% { opacity: 0; }
	}
	@keyframes typewriter {
		from { width: 0; }
		to { width: 100%; }
	}
</style>
