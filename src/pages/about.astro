---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="About | Othniel Agera">
	<Header />
	<section class="pt-12 space-y-12">
		<div class="space-y-4">
			<div class="text-teal-400">$ whoami</div>
			<h1 class="text-4xl font-bold text-white">Othniel Agera</h1>
			<p class="text-gray-400">Software Engineer @ Flutterwave</p>
		</div>

		<div class="space-y-4">
			<div class="text-teal-400">$ cat bio.txt</div>
			<div class="max-w-[65ch] text-gray-300 leading-relaxed space-y-4">
				<p>
					I am a graduate of Mathematics and Computer Science with a focus on
					building high-scale distributed systems. Currently at Flutterwave, I
					architect mission-critical backend services, focusing on performance
					optimization and infrastructure cost-efficiency.
				</p>
				<p>
					I started my journey as a software developer crafting responsive UIs
					with React.js before transitioning to backend work in which I have
					engineered complex data pipelines and logging systems. I have
					transitioned legacy systems to be more modern, optimized stacks (like
					attempting to move from MongoDB to Redis for an internal logging
					system or Datadog to LGTM) to improve data retrieval speeds and
					operational reliability.
				</p>
				<p>
					I am currently learning Rust to further enhance my backend development
					skills and explore systems programming. I am passionate about building
					scalable, efficient, and maintainable software that delivers
					real-world impact.
				</p>
			</div>
		</div>

		<div class="space-y-4">
			<div class="text-teal-400">$ ls stack/</div>
			<div
				class="flex flex-wrap gap-x-4 gap-y-2 text-sm text-gray-500 font-mono"
			>
				{
					[
						"Node.js",
						"TypeScript",
						"Java",
						"PostgreSQL",
						"Kafka",
						"Redis",
						"LGTM Stack",
						"GraphQL",
						"Docker",
						"Rust",
					].map((tech) => (
						<span class="before:content-['•'] before:mr-2 before:text-teal-800">
							{tech}
						</span>
					))
				}
			</div>
		</div>

		<div class="pt-12">
			<a
				href="/"
				class="text-teal-400 hover:text-teal-300 transition-colors font-mono"
			>
				$ cd ..
			</a>
		</div>
	</section>
	<Footer />
</BaseLayout>
